# FIND-RLB Environment Configuration
# Deployment: Hedera Testnet
# Date: March 4, 2026

# ==================== DJANGO SETTINGS ====================
SECRET_KEY=find-rlb-django-secret-key-2026-hedera-deployment
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,*.hedera.test

# ==================== DATABASE ====================
DATABASE_URL=sqlite:///db.sqlite3
DB_NAME=find_rlb_prod
DB_USER=postgres
DB_PASSWORD=password123
DB_HOST=localhost
DB_PORT=5432

# ==================== HEDERA CONFIGURATION ====================
# IMPORTANT: Replace these with your actual Hedera testnet credentials from:
# https://portal.hedera.com

# Hedera Testnet Account ID (format: 0.0.xxxxx)
HEDERA_ACCOUNT_ID=0.0.7974203

# Hedera Testnet Private Key (ECDSA format - without 0x prefix for SDK compatibility)
HEDERA_PRIVATE_KEY=3b980fa28f0c1e58d677ef8ff75e248ac16f37fc5de373a236b39fe04e9a447a

# Hedera Network: testnet or mainnet
HEDERA_NETWORK=testnet

# ==================== BLOCKCHAIN SETTINGS ====================
# Web3 Provider (for EVM compatibility)
WEB3_PROVIDER=https://testnet.hedera.hashgraph.com:8545

# Chain ID for Hedera
CHAIN_ID=296

# ==================== TOKEN CONFIGURATION ====================
# FIND Token Details
FIND_TOKEN_SYMBOL=FIND
FIND_TOKEN_DECIMALS=2
FIND_TOKEN_INITIAL_SUPPLY=1000000000

# USDC Stablecoin on Hedera (testnet)
USDC_TOKEN_ID=0.0.456858

# ==================== API SETTINGS ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ==================== AI SETTINGS ====================
OPENAI_API_KEY=your_openai_api_key_here

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# ==================== JWT SETTINGS ====================
JWT_SECRET_KEY=find-rlb-jwt-secret-key-2026
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# ==================== IPFS SETTINGS ====================
IPFS_GATEWAY=https://gateway.ipfs.io
IPFS_API_URL=http://localhost:5001

# ==================== FRONTEND SETTINGS ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_CHAIN_ID=296

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=find_rlb_deployment.log

# ==================== SECURITY ====================
ALLOWED_PAYMENT_METHODS=hbar,usdc,bank_transfer
MAX_TRANSACTION_AMOUNT=1000000
MIN_TRANSACTION_AMOUNT=1

# ==================== EMAIL SETTINGS (Optional) ====================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# ==================== DEPLOYMENT FLAGS ====================
PRODUCTION=False
ENABLE_CONTRACT_DEPLOYMENT=True
ENABLE_AI_AGENTS=True
ENABLE_P2P_COMMUNITY=True
